# CloseCRM — Firebase configuration
# 1. Create a free project at https://console.firebase.google.com
# 2. Add a Web App, then copy its config values below.
# 3. In the Firebase console enable: Authentication → Sign-in method → Email/Password,
#    and Firestore Database → Create database (production mode).
# 4. Paste the Firestore rules from firestore.rules into the Rules tab.
# 5. Copy this file to ".env" and fill in the values, then restart `npm run dev`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
